APP_NAME="Mailchimp Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

ADMIN_EMAIL=
CONFIG_BASE_PATH=config

# Maximum age in hours before an open INCREMENTAL sync revision is considered stale and abandoned.
# Incremental syncs should complete quickly (within hours), so 48 hours is reasonable.
# Default: 48 hours
MAX_REVISION_AGE_HOURS=48

# Maximum age in hours before an open FULL sync revision is considered stale and abandoned.
# Full syncs can take days to complete for large datasets, so this should be much longer.
# Default: 240 hours (10 days)
MAX_FULL_SYNC_REVISION_AGE_HOURS=240

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=4306
DB_DATABASE=mailchimp
DB_USERNAME=mailchimp
DB_PASSWORD=mailchimp

BROADCAST_DRIVER=log
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_DRIVER=sync

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=mail@example.com
MAIL_FROM_NAME="Mailchimp Service"

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
